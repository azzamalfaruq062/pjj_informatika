</head>

<body>

<div class="box"> <!-- Kotak utama -->

```
<h2>Hitung IPK</h2> <!-- Judul -->

<!-- ===== INPUT USER ===== -->
<input id="n1" placeholder="Nilai 1"><br> <!-- Input nilai pertama -->
<input id="n2" placeholder="Nilai 2"><br> <!-- Input nilai kedua -->
<input id="n3" placeholder="Nilai 3"><br> <!-- Input nilai ketiga -->
<input id="n4" placeholder="Nilai 4"><br> <!-- Input nilai keempat -->

<!-- ===== TOMBOL AKSI ===== -->
<button onclick="hitung()">Hitung</button> <!-- Saat diklik, jalankan fungsi hitung() -->

<!-- ===== TEMPAT HASIL ===== -->
<p id="hasil"></p> <!-- Hasil akan muncul di sini -->
```

</div>

<script>
/* ===== JAVASCRIPT (LOGIKA / INTERAKTIF) ===== */

function hitung() { // Fungsi dijalankan saat tombol diklik

  // === 1. AMBIL INPUT DARI USER ===
  let n1 = document.getElementById("n1").value; // Ambil nilai dari input 1
  let n2 = document.getElementById("n2").value; // Ambil nilai dari input 2
  let n3 = document.getElementById("n3").value; // Ambil nilai dari input 3
  let n4 = document.getElementById("n4").value; // Ambil nilai dari input 4

  // === 2. VALIDASI INPUT ===
  if (n1=="" || n2=="" || n3=="" || n4=="") { 
    // Jika ada yang kosong
    document.getElementById("hasil").innerHTML = "Isi semua nilai dulu!"; 
    return; // Hentikan program
  }

  // === 3. UBAH KE ANGKA ===
  n1 = +n1; // Mengubah string ke angka
  n2 = +n2;
  n3 = +n3;
  n4 = +n4;

  // === 4. HITUNG RATA-RATA (IPK) ===
  let ipk = (n1+n2+n3+n4)/4; // Rumus IPK

  // === 5. TAMPILKAN HASIL ===
  document.getElementById("hasil").innerHTML =
    "IPK: " + ipk.toFixed(2); // Tampilkan dengan 2 angka di belakang koma
}
</script>

</body>
</html>